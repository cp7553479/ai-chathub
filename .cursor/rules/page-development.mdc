# Next.js App Router 页面开发框架

本规则定义了基于 Next.js 15 App Router 的完整页面开发框架，包含响应式布局、路由结构、状态管理等核心要素。

## 📁 标准文件结构

### 路由层次结构
```
app/
├── [variants]/                 # 动态路由变体（响应式+国际化）
│   ├── layout.tsx              # 根布局（GlobalProvider）
│   └── (main)/                 # 路由组
│       ├── layout.tsx          # 主布局（ServerLayout）
│       └── {page}/             # 具体页面
│           ├── layout.tsx      # 页面布局
│           ├── page.tsx        # 页面入口
│           ├── @{slot}/        # 并行路由槽位（可选）
│           │   ├── _layout/    # 槽位布局
│           │   ├── features/   # 槽位功能组件
│           │   └── default.tsx # 槽位默认页面
│           ├── (group)/        # 路由组（可选）
│           │   ├── layout.tsx  # 组布局
│           │   └── page.tsx    # 组页面
│           ├── _layout/        # 页面布局组件
│           │   ├── Desktop/    # 桌面端布局
│           │   ├── Mobile/     # 移动端布局
│           │   └── type.ts     # 布局类型定义
│           └── features/       # 页面功能组件
```

### 组件层次结构
```
features/{PageName}/
├── components/                 # 页面专用组件
├── hooks/                     # 页面专用hooks
├── services/                  # 页面专用服务
├── store/                     # 页面专用状态
└── types/                     # 页面专用类型
```

### 全局资源结构
```
src/
├── store/                     # 全局状态管理
│   ├── {domain}/              # 按业务域划分
│   │   ├── store.ts           # Store 主入口
│   │   ├── initialState.ts    # 初始状态
│   │   ├── selectors.ts       # 状态选择器
│   │   └── slices/            # 状态切片
│   │       ├── {feature}/     # 功能切片
│   │       │   ├── action.ts  # 操作方法
│   │       │   ├── initialState.ts
│   │       │   └── selectors.ts
│   │       └── index.ts
│   └── middleware/            # 状态中间件
├── hooks/                     # 全局 Hooks
│   ├── useFetch*.ts           # 数据获取 Hooks
│   ├── useInit*.ts            # 初始化 Hooks
│   ├── useSwitch*.ts          # 切换操作 Hooks
│   └── use*.ts                # 通用功能 Hooks
└── services/                  # 全局服务层
    ├── {domain}/              # 按业务域划分
    │   ├── api.ts             # API 接口
    │   ├── types.ts           # 服务类型
    │   └── utils.ts           # 工具函数
    └── index.ts
```

## 🏗️ 核心开发模式

### 1. 响应式布局判断
```typescript
// 服务端判断（主要方式）
const isMobile = await RouteVariants.getIsMobile(props);

// 客户端判断（辅助方式）
const isMobile = useIsMobile();
```

### 2. ServerLayout 组件注册
```typescript
// layout.tsx
import ServerLayout from '@/components/server/ServerLayout';
import Desktop from './_layout/Desktop';
import Mobile from './_layout/Mobile';

interface LayoutProps {
  children: ReactNode;
  // 定义并行路由槽位
  slotName: ReactNode;
}

const Layout = ServerLayout<LayoutProps>({ Desktop, Mobile });
export default Layout;
```

### 3. 并行路由槽位
```typescript
// @{slot}/default.tsx
const SlotPage = async (props: DynamicLayoutProps) => {
  const isMobile = await RouteVariants.getIsMobile(props);
  
  return (
    <SlotLayout isMobile={isMobile}>
      <SlotContent />
    </SlotLayout>
  );
```

### 3. 页面组件结构
```typescript
// page.tsx
const Page = async (props: DynamicLayoutProps) => {
  const { isMobile } = await parsePageMetaProps(props);
  
  return <Client mobile={isMobile} />;
};

// Client.tsx
const Client = ({ mobile }: { mobile: boolean }) => {
  return <PageContent />;
};
```

### 4. 懒加载优化
```typescript
// 组件懒加载
const LazyComponent = lazy(() => import('./features/Component'));

// 使用Suspense包装
<Suspense fallback={<Loading />}>
  <LazyComponent />
</Suspense>
```

### 5. 全局状态管理集成
```typescript
// 全局 Store 使用
import { useChatStore } from '@/store/chat';
import { useSessionStore } from '@/store/session';
import { useGlobalStore } from '@/store/global';

// 在组件中使用
const Component = () => {
  const [messages, sendMessage] = useChatStore((s) => [
    s.messagesMap,
    s.sendMessage,
  ]);
  
  const [activeId, switchSession] = useSessionStore((s) => [
    s.activeId,
    s.switchSession,
  ]);
  
  return <div>{/* 组件内容 */}</div>;
};
```

### 6. 全局 Hooks 使用
```typescript
// 数据获取 Hooks
import { useFetchMessages } from '@/hooks/useFetchMessages';
import { useFetchTopics } from '@/hooks/useFetchTopics';
import { useInitAgentConfig } from '@/hooks/useInitAgentConfig';

// 在组件中使用
const PageComponent = () => {
  useFetchMessages();    // 自动获取消息
  useFetchTopics();      // 自动获取话题
  const { isLoading } = useInitAgentConfig();
  
  return <div>{/* 页面内容 */}</div>;
};
```

### 7. 页面级状态管理（可选）
```typescript
// 仅在需要页面专用状态时使用
interface PageStore {
  data: PageData[];
  loading: boolean;
  
  fetchData: () => Promise<void>;
  updateData: (data: PageData) => void;
}

const usePageStore = create<PageStore>((set, get) => ({
  // 实现状态逻辑
}));
```

